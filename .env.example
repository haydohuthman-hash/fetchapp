# --- Supabase (optional) ---
# Vite only exposes variables prefixed with VITE_ (not NEXT_PUBLIC_).
# Copy to `.env.local` for local dev. `.env.local` is gitignored.
#
# Dashboard: Project Settings → API → Project URL + anon public key
# (your “publishable” key goes here as VITE_SUPABASE_ANON_KEY).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional — localhost / 127.0.0.1 only, `npm run dev` only: auto sign-in when there is no session.
# Create the same user in Supabase (Auth → Users) with password demo12345678 (or set both vars below).
# VITE_DEV_AUTO_SIGNIN_EMAIL=demo@fetch.local
# Omit password to use the default demo password (demo12345678), or override:
# VITE_DEV_AUTO_SIGNIN_PASSWORD=demo12345678
#
# Same email is used for dev-only marketplace “My listings” mocks + extra Drops videos in the feed.
# Override only if you use a different mailbox (must match Express env below):
# VITE_DEV_DEMO_USER_EMAIL=demo@fetch.local
#
# Express (npm run dev API): allow header auth from the Vite app and align demo email with the browser session.
# FETCH_ALLOW_HEADER_AUTH=1
# FETCH_DEV_DEMO_USER_EMAIL=demo@fetch.local

# OAuth redirect base (Google / Apple). The app appends `/app` automatically. In Supabase Dashboard → Auth → URL
# configuration, allow redirects: https://www.tryfetchit.app/app and http://localhost:5174/app (and your preview host if any).
# Production builds still reject localhost in this URL when the site is not opened on localhost.
# VITE_SITE_URL=https://www.tryfetchit.app
# Optional exact override (still gets `/app` if missing): VITE_SUPABASE_REDIRECT_URL=https://www.tryfetchit.app

# Server-only (Express). Never use in browser or VITE_*.
# Same project URL as the dashboard (https://….supabase.co) — useful for admin client helpers.
SUPABASE_URL=
# Same publishable anon key as VITE_SUPABASE_ANON_KEY — required for user-scoped Supabase inserts (RLS + auth.uid()).
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# When SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY are set, the API stores peer marketplace
# listings, Stripe seller rows, listing checkout orders, and seller ledger in Supabase
# (see scripts/supabase-marketplace-listings.sql). Without them, listings fall back to a
# local JSON file (ephemeral on Vercel-style /tmp).

# --- Postgres (Express / `pg` pool) ---
# When set, enables Drops feed persistence, optional `FETCH_AUTH_USERS_DB`, store merge, etc.
#
# Supabase: Settings → Database → Connection string → URI.
# Replace [YOUR-PASSWORD] with the database password (not your Supabase account password).
#
# Direct (IPv6-friendly):
#   postgresql://postgres:[YOUR-PASSWORD]@db.<project-ref>.supabase.co:5432/postgres
#
# If your network is IPv4-only and direct fails, use the Session pooler string from the same page
# (labeled for IPv4 / serverless) — host and port differ from db.*:5432.
DATABASE_URL=

# --- Drops (Supabase Storage + Postgres) ---
#
# Media: the app uploads video/images from the browser to Supabase Storage (bucket `drops` by default).
# Set VITE_SUPABASE_URL + VITE_SUPABASE_ANON_KEY above. Create Storage bucket `drops` (or override name below)
# and policies so clients can upload and the returned public URLs are readable for playback.
# VITE_SUPABASE_DROP_BUCKET=drops
#
# Metadata: Postgres stores drop rows and media URLs. When DATABASE_URL is set on the API,
# GET /api/drops/feed includes `"database": true`. POST /api/publish uses the same pool.
#
# Strong random secret so session cookies verify across deploys and instances (marketplace + Drops publish).
# Production: avoid the default; use at least 24 characters.
FETCH_SESSION_SECRET=
