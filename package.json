{
  "name": "fetch",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently -n server,vite -c blue,magenta \"npm run server\" \"vite\"",
    "dev:e2e-stack": "concurrently -n server,vite -c blue,magenta \"cross-env PORT=8792 npm run server\" \"cross-env FETCH_DEV_PORT=5179 FETCH_DEV_API_PORT=8792 vite\"",
    "server": "tsx server/index.js",
    "build": "tsc -b && vite build",
    "test": "tsx --test server/lib/booking-flow.test.js server/llm/fetchChatParse.test.js src/lib/booking/bookingLifecycle.test.ts src/lib/booking/bookingSessionPhase.test.ts src/lib/booking/specialtyItemCatalog.test.ts src/lib/booking/tripSheetPhase.test.ts src/lib/drops/uploadDropMediaPaths.test.ts",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "preview": "vite preview",
    "generate:supply-images": "tsx scripts/generate-supply-product-images.ts",
    "seed:products": "node scripts/seed-products-from-store-catalog.mjs",
    "verify:drops-deploy": "node scripts/verify-drops-deploy.mjs"
  },
  "dependencies": {
    "@googlemaps/markerclusterer": "^2.6.2",
    "@react-google-maps/api": "^2.20.8",
    "@stripe/react-stripe-js": "^6.1.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.102.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^1.8.0",
    "mapbox-gl": "^3.21.0",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "stripe": "^22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1"
  }
}
